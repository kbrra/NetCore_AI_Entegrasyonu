@{
    ViewData["Title"] = "Yemek Tarifi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yemek Tarifi Önerisi</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    
</head>
<body>
    <div class="container">
        <header>
            <div class="badge">🍳 AI Destekli</div>
            <h1>Malzemeni Gir,<br /><span>Tarifinizi Alalım</span></h1>
            <p class="subtitle">Elinizdeki malzemelere göre size özel tarif öneriyoruz.</p>
        </header>

        <div class="card">
            <form method="post" action="/Default/CreateRecipe">
                <label>Malzemeleriniz</label>
                <textarea name="ingrediends"
                          id="ingrediends"
                          placeholder="Örnek: domates, soğan, yumurta, zeytinyağı, peynir..."></textarea>

                <div class="examples">
                    <button type="button" class="example-tag" onclick="fillExample('domates, soğan, yumurta, zeytinyağı')">🥚 Kahvaltılık</button>
                    <button type="button" class="example-tag" onclick="fillExample('tavuk, sarımsak, limon, patates')">🍗 Tavuklu</button>
                    <button type="button" class="example-tag" onclick="fillExample('makarna, domates, kıyma, soğan')">🍝 Makarna</button>
                    <button type="button" class="example-tag" onclick="fillExample('pirinç, tavuk suyu, havuç, soğan')">🍲 Çorba</button>
                </div>

                <button type="submit" class="submit-btn">✨ Tarif Öner</button>
            </form>

            @if (ViewBag.recipe != null)
            {
                <div class="divider">
                    <div class="divider-line"></div>
                    <div class="divider-icon">🍽️</div>
                    <div class="divider-line"></div>
                </div>

                <div class="recipe-box">
                    <div class="recipe-title">📖 Tarifiniz Hazır!</div>
                    <div class="recipe-content">@ViewBag.recipe</div>
                </div>
            }
        </div>
    </div>

    <script>
        function fillExample(text) {
            document.getElementById('ingrediends').value = text;
        }
    </script>
</body>
</html>
<style>
    :root {
        --cream: #faf6f0;
        --brown: #2c1a0e;
        --orange: #e8621a;
        --orange-light: #f4834a;
        --tan: #d4a574;
        --tan-light: #f0e0cc;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: var(--cream);
        color: var(--brown);
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        background-image: radial-gradient(circle at 20% 20%, #f5e6d3 0%, transparent 50%), radial-gradient(circle at 80% 80%, #ffe8d6 0%, transparent 50%);
    }

    .container {
        max-width: 860px;
        margin: 0 auto;
        padding: 60px 24px;
    }

    header {
        text-align: center;
        margin-bottom: 60px;
        animation: fadeDown 0.8s ease both;
    }

    .badge {
        display: inline-block;
        background: var(--orange);
        color: white;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 6px 16px;
        border-radius: 20px;
        margin-bottom: 20px;
    }

    h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.4rem, 6vw, 3.8rem);
        line-height: 1.15;
        color: var(--brown);
        margin-bottom: 16px;
    }

        h1 span {
            color: var(--orange);
        }

    .subtitle {
        color: #7a5c45;
        font-size: 1.05rem;
        font-weight: 300;
    }

    .card {
        background: white;
        border-radius: 24px;
        padding: 48px;
        box-shadow: 0 4px 40px rgba(44, 26, 14, 0.08);
        animation: fadeUp 0.8s ease 0.2s both;
    }

    label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--orange);
        margin-bottom: 12px;
    }

    textarea {
        width: 100%;
        padding: 20px;
        border: 2px solid var(--tan-light);
        border-radius: 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        color: var(--brown);
        background: var(--cream);
        resize: none;
        height: 130px;
        transition: border-color 0.3s, box-shadow 0.3s;
        outline: none;
    }

        textarea:focus {
            border-color: var(--orange);
            box-shadow: 0 0 0 4px rgba(232, 98, 26, 0.1);
        }

        textarea::placeholder {
            color: #c4a882;
        }

    .examples {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
        margin-bottom: 32px;
    }

    .example-tag {
        background: var(--tan-light);
        color: #7a5c45;
        font-size: 12px;
        padding: 6px 14px;
        border-radius: 20px;
        cursor: pointer;
        border: none;
        font-family: 'DM Sans', sans-serif;
        transition: background 0.2s, color 0.2s;
    }

        .example-tag:hover {
            background: var(--orange);
            color: white;
        }

    .submit-btn {
        width: 100%;
        padding: 18px;
        background: var(--orange);
        color: white;
        border: none;
        border-radius: 16px;
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        letter-spacing: 0.5px;
        transition: background 0.3s, transform 0.2s, box-shadow 0.3s;
        position: relative;
        overflow: hidden;
    }

        .submit-btn:hover {
            background: var(--orange-light);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(232, 98, 26, 0.3);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

    .divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 48px 0 40px;
    }

    .divider-line {
        flex: 1;
        height: 1px;
        background: var(--tan-light);
    }

    .divider-icon {
        font-size: 1.4rem;
    }

    .recipe-box {
        background: linear-gradient(135deg, #fff9f4, #fff3e8);
        border: 2px solid var(--tan-light);
        border-radius: 20px;
        padding: 40px;
        animation: fadeUp 0.6s ease both;
    }

    .recipe-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        color: var(--orange);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .recipe-content {
        font-size: 0.97rem;
        line-height: 1.85;
        color: #4a3020;
        white-space: pre-wrap;
    }

    .error-box {
        background: #fff0f0;
        border: 2px solid #ffcccc;
        border-radius: 16px;
        padding: 20px 24px;
        color: #cc3333;
        font-size: 0.95rem;
    }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>