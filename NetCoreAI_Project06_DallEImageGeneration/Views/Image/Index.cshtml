@{
    ViewData["Title"] = "DALL-E Görsel Oluşturucu";
}


<div class="container">
    <h2>✨ DALL-E Görsel Oluşturucu</h2>
    <p class="subtitle">Aklındaki görseli tarif et, yapay zeka oluştursun</p>

    <form method="post">
        <div class="input-row">
            <input type="text" name="prompt" placeholder="Örn: Uzayda yüzen bir kedi..." />
            <button type="submit">Oluştur</button>
        </div>
    </form>

    @if (ViewBag.ImageUrl != null)
    {
        <div class="result">
            <img src="@ViewBag.ImageUrl" />
            <p>"@ViewBag.Prompt"</p>
        </div>
    }
    @if (ViewBag.Error != null)
    {
        <p style="color:red;">@ViewBag.Error</p>
    }

</div>

<style>
    body {
        background: #0f0f0f;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .container {
        max-width: 700px;
        margin: 60px auto;
        text-align: center;
    }

    h2 {
        font-size: 2.2rem;
        margin-bottom: 8px;
        background: linear-gradient(90deg, #a78bfa, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    p.subtitle {
        color: #888;
        margin-bottom: 30px;
    }

    .input-row {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    input[type="text"] {
        width: 100%;
        padding: 14px 18px;
        border-radius: 12px;
        border: 1px solid #333;
        background: #1a1a1a;
        color: white;
        font-size: 1rem;
        outline: none;
    }

        input[type="text"]:focus {
            border-color: #a78bfa;
        }

    button {
        padding: 14px 24px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(90deg, #a78bfa, #60a5fa);
        color: white;
        font-size: 1rem;
        cursor: pointer;
        white-space: nowrap;
    }

        button:hover {
            opacity: 0.85;
        }

    .result {
        margin-top: 40px;
    }

        .result img {
            width: 100%;
            border-radius: 16px;
            box-shadow: 0 0 40px rgba(167, 139, 250, 0.3);
        }

        .result p {
            margin-top: 12px;
            color: #aaa;
            font-style: italic;
        }
</style>